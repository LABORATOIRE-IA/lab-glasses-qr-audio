reference/

# --- Secrets ---
.env
.env.*
*.key
*.pem
secrets/

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.pytest_cache/

# --- Artefacts générés ---
qr-codes/out/
*.mp3
*.wav
*.m4a
